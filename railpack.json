{
  "$schema": "https://schema.railpack.com",
  "provider": "python",
  "packages": {
    "python": "3.10"
  },
  "steps": {
    "install": {
      "commands": [
        "python -m pip install --upgrade pip",
        "pip install -r backend/requirements.runtime.txt"
      ]
    }
  },
  "deploy": {
    "startCommand": "cd backend && uvicorn server:app --host 0.0.0.0 --port $PORT"
  }
}
